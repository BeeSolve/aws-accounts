{
  "name": "@beesolve/aws-accounts",
  "version": "1.7.10",
  "description": "AWS Organizations and IAM Identity Center management CLI",
  "keywords": [],
  "license": "MIT",
  "author": "",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BeeSolve/aws-accounts.git"
  },
  "bin": {
    "aws-accounts": "bin/cli.js"
  },
  "files": [
    "bin",
    "dist",
    "!dist/**/*.test.js",
    "dist-lambda",
    "templates"
  ],
  "type": "module",
  "main": "dist/cli.js",
  "exports": {
    ".": "./dist/cli.js",
    "./security": {
      "types": "./dist/security.d.ts",
      "default": "./dist/security.js"
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "npm run clean && esbuild $(find src -name '*.ts' ! -name '*.test.ts') --platform=node --target=node24 --format=esm --outdir=dist --outbase=src && tsc -p tsconfig.declarations.json",
    "build:lambda": "node scripts/buildLambda.ts",
    "build:tests": "find dist -name '*.test.js' -delete && esbuild \"src/**/*.test.ts\" --platform=node --target=node24 --format=esm --outdir=dist --outbase=src",
    "cli": "npm run build && node dist/cli.js",
    "typecheck": "tsc --noEmit",
    "test": "npm run build && npm run build:tests && node --experimental-test-module-mocks --test \"dist/**/*.test.js\"",
    "prepublishOnly": "npm run typecheck && npm run build && npm run build:lambda"
  },
  "dependencies": {
    "@aws-sdk/client-account": "^3.1063.0",
    "@aws-sdk/client-cloudformation": "^3.1063.0",
    "@aws-sdk/client-cloudwatch-logs": "3.1065.0",
    "@aws-sdk/client-config-service": "3.1065.0",
    "@aws-sdk/client-iam": "^3.1063.0",
    "@aws-sdk/client-identitystore": "^3.1063.0",
    "@aws-sdk/client-lambda": "^3.1063.0",
    "@aws-sdk/client-organizations": "^3.1063.0",
    "@aws-sdk/client-s3": "^3.1063.0",
    "@aws-sdk/client-sso-admin": "^3.1063.0",
    "@aws-sdk/client-sts": "^3.1063.0",
    "@aws-sdk/credential-providers": "^3.1063.0",
    "@aws-sdk/s3-request-presigner": "^3.1063.0",
    "@beesolve/iam-policy-ts": "^26.6.6",
    "esbuild": "^0.28.0",
    "valibot": "^1.4.1"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@types/node": "^24.13.1",
    "fast-check": "^4.8.0",
    "typescript": "^6.0.3"
  },
  "volta": {
    "node": "26.1.0",
    "npm": "11.14.1"
  }
}
