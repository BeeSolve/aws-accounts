{
  "name": "@beesolve/aws-accounts",
  "version": "1.0.0",
  "description": "Local-first AWS Organizations and IAM Identity Center management CLI",
  "main": "dist/cli.js",
  "bin": {
    "aws-accounts": "dist/cli.js"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "npm run clean && esbuild $(find src -name '*.ts' ! -name '*.test.ts') --platform=node --target=node24 --format=esm --outdir=dist --outbase=src && chmod +x dist/cli.js",
    "build:tests": "find dist -name '*.test.js' -delete && esbuild \"src/**/*.test.ts\" --platform=node --target=node24 --format=esm --outdir=dist --outbase=src",
    "cli": "npm run build && node dist/cli.js",
    "typecheck": "tsc --noEmit",
    "test": "npm run build && npm run build:tests && node --test \"dist/**/*.test.js\""
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "type": "module",
  "dependencies": {
    "@aws-sdk/client-identitystore": "^3.1043.0",
    "@aws-sdk/client-organizations": "^3.1043.0",
    "@aws-sdk/client-sso-admin": "^3.1043.0",
    "@aws-sdk/credential-providers": "^3.1043.0",
    "@beesolve/iam-policy-ts": "^26.0.0",
    "esbuild": "^0.28.0",
    "valibot": "^1.4.0"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "typescript": "^6.0.3"
  },
  "volta": {
    "node": "26.1.0",
    "npm": "11.14.1"
  }
}
